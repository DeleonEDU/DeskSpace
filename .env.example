# Database Credentials
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_db_password_here

# Django Secret Key (Shared across all services for JWT validation)
# Generate a new one for production!
SECRET_KEY=your_shared_secret_key_here

# Frontend Environment
NODE_ENV=development

# Allowed Origins for CORS (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:5173

# Allowed Hosts for Django (comma separated)
ALLOWED_HOSTS=localhost,127.0.0.1,api_gateway,auth_service,space_service,booking_service
