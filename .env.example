# Copy this file to .env and adjust values:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.

# Database Credentials (local Docker defaults: postgres / postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Django Secret Key (shared across all services for JWT validation)
# Generate a new one for production!
SECRET_KEY=your_shared_secret_key_here

# Frontend Environment
NODE_ENV=development

# Allowed Origins for CORS (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:5173

# Allowed Hosts for Django (comma separated)
ALLOWED_HOSTS=localhost,127.0.0.1,api_gateway,auth_service,space_service,booking_service

# Inter-service HTTP (booking -> space validation)
SPACE_SERVICE_URL=http://space_service:8002
SPACE_SERVICE_TIMEOUT=5
# Valid RFC Host header for Django 6 (docker names like space_service are rejected)
SPACE_SERVICE_HOST_HEADER=localhost
